# Supabase connection (from: npx supabase start)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-side only, NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# GitHub personal access token (repo read scope)
GITHUB_TOKEN=

# PII encryption key for pgcrypto field-level encryption (PROF-06)
# Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=
