{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["chrome"]
  },
  "include": ["**/*.ts", "**/*.tsx", ".wxt/types.d.ts"],
  "exclude": ["node_modules", ".output", ".wxt"]
}
